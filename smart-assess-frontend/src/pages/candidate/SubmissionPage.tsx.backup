import { useState, useEffect } from 'react';
import { Link, useNavigate } from 'react-router-dom';
import { ArrowLeft, CheckCircle, AlertCircle, Upload, FileText, Loader2, Brain, Star } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Progress } from '@/components/ui/progress';
import { Badge } from '@/components/ui/badge';
import { useAuth } from '@/hooks/useApiHooks';
import { useCVAnalysis } from '@/hooks/useApiHooks';

interface SelectedPosition {
  id: number;
  title: string;
  description: string;
}

interface UploadedCV {
  name: string;
  size: number;
  type: string;
}

export default function SubmissionPage() {
  const [selectedPositions, setSelectedPositions] = useState<any[]>([]);
  const [cvFile, setCvFile] = useState<File | null>(null);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [submitStatus, setSubmitStatus] = useState<'idle' | 'uploading' | 'processing' | 'success' | 'error'>('idle');
  const [errorMessage, setErrorMessage] = useState<string | null>(null);
  const [savedCV, setSavedCV] = useState<any>(null);
  const [showCVUpload, setShowCVUpload] = useState(false);
  const { user } = useAuth();
  const navigate = useNavigate();
  const { analyzeCV, isPending, analysis, error } = useCVAnalysis();

  useEffect(() => {
    // Charger les sélections depuis sessionStorage (session en cours uniquement)
    const saved = sessionStorage.getItem('selectedPositions');
    if (saved) {
      setSelectedPositions(JSON.parse(saved));
    }
    
    // Vérifier si on vient de la page PositionsPage (nouvelle session)
    const fromPositionsPage = sessionStorage.getItem('fromPositionsPage');
    
    // Prioriser sessionStorage pour le CV (upload immédiat), puis localStorage (persistance)
    let savedCV = sessionStorage.getItem('uploadedCV');
    if (!savedCV) {
      savedCV = localStorage.getItem('uploadedCV');
    }
    
    if (savedCV && fromPositionsPage === 'true') {
      try {
        const cvData = JSON.parse(savedCV);
        setSavedCV(cvData);
        // Ne pas afficher l'upload si un CV est déjà uploadé ET qu'on vient de PositionsPage
        setShowCVUpload(false);
        // Nettoyer le sessionStorage
        sessionStorage.removeItem('fromPositionsPage');
      } catch (error) {
        console.error('Erreur lors du chargement du CV:', error);
        setShowCVUpload(true);
      }
    } else {
      // Si pas de CV ou si on ne vient pas de PositionsPage, afficher l'upload
      setShowCVUpload(true);
      // Nettoyer le sessionStorage au cas où
      sessionStorage.removeItem('fromPositionsPage');
    }
  }, []);

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      // Validation du fichier
      const validTypes = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
      const maxSize = 5 * 1024 * 1024; // 5MB

      if (!validTypes.includes(file.type)) {
        setErrorMessage('Format de fichier non valide. Veuillez utiliser PDF, DOC ou DOCX.');
        return;
      }

      if (file.size > maxSize) {
        setErrorMessage('Le fichier est trop volumineux. Taille maximale: 5MB.');
        return;
      }

      setCvFile(file);
      
      // Sauvegarder le CV dans localStorage ET sessionStorage pour la persistance
      const cvData: UploadedCV = {
        name: file.name,
        size: file.size,
        type: file.type
      };
      localStorage.setItem('uploadedCV', JSON.stringify(cvData));
      sessionStorage.setItem('uploadedCV', JSON.stringify(cvData)); // Pour le transfert immédiat
      setSavedCV(cvData);
      setShowCVUpload(false); // Cacher l'upload après sélection
      
      setErrorMessage(null);
    }
  };

  const handleSubmit = async () => {
    // Si pas de CV mais un CV précédemment uploadé, le récupérer
    if (!cvFile && savedCV) {
      // Le CV est déjà uploadé, pas besoin de reuploader
      setErrorMessage(null);
    } else if (!cvFile && !savedCV) {
      setErrorMessage('Veuillez sélectionner un fichier CV et au moins un poste.');
      return;
    }
    
    if (selectedPositions.length === 0) {
      setErrorMessage('Veuillez sélectionner au moins un poste.');
      return;
    }

    setIsSubmitting(true);
    setSubmitStatus('uploading');
    setErrorMessage(null);

    try {
      // TODO: Implémenter uploadCV et createCandidature dans useApiHooks
      const cvResponse = { cvUrl: '' }; // await candidateService.uploadCV(user?.id || 0, cvFile || savedCV);
      
      setSubmitStatus('processing');

      // TODO: Implémenter createCandidature dans useApiHooks
      const candidaturePromises = selectedPositions.map(position => 
        Promise.resolve({ id: 1 }) // await candidateService.createCandidature({
          // candidateId: user?.id,
          // internshipPositionId: position.id,
          // cvUrl: cvResponse.cvUrl
        // })
      );

      await Promise.all(candidaturePromises);

      // Étape 3: Nettoyer le localStorage et rediriger
      localStorage.removeItem('selectedPositions');
      localStorage.removeItem('uploadedCV'); // Nettoyer aussi le CV
      setSubmitStatus('success');

      // Rediriger vers la page des candidatures après 2 secondes
      setTimeout(() => {
        navigate('/candidat/candidatures');
      }, 2000);

    } catch (error: any) {
      console.error('Erreur lors de la soumission:', error);
      setSubmitStatus('error');
      setErrorMessage(error.response?.data?.error || 'Erreur lors de la soumission des candidatures. Veuillez réessayer.');
    } finally {
      setIsSubmitting(false);
    }
  };

  const handleClearCV = () => {
    localStorage.removeItem('uploadedCV');
    sessionStorage.removeItem('uploadedCV'); // Nettoyer aussi sessionStorage
    setCvFile(null);
    setSavedCV(null);
    setShowCVUpload(true);
    setSubmitStatus('idle');
    setErrorMessage(null);
    // Nettoyer aussi le sessionStorage
    sessionStorage.removeItem('fromPositionsPage');
    sessionStorage.removeItem('selectedPositions');
  };

  const goBack = () => {
    navigate('/candidat/postes');
  };

  const getStatusMessage = () => {
    switch (submitStatus) {
      case 'uploading':
        return 'Téléchargement du CV...';
      case 'processing':
        return 'Création des candidatures...';
      case 'success':
        return 'Candidatures soumises avec succès !';
      case 'error':
        return 'Erreur lors de la soumission';
      default:
        return '';
    }
  };

  const getStatusColor = () => {
    switch (submitStatus) {
      case 'uploading':
        return 'text-blue-600';
      case 'processing':
        return 'text-amber-600';
      case 'success':
        return 'text-green-600';
      case 'error':
        return 'text-red-600';
      default:
        return '';
    }
  };

  return (
    <div className="container mx-auto p-6">
      <div className="flex justify-between items-center mb-6">
        <div>
          <h1 className="text-2xl font-bold">Soumission des candidatures</h1>
          <p className="text-gray-600 mt-1">Finalisez vos candidatures</p>
        </div>
        <Button variant="outline" onClick={goBack} className="flex items-center gap-2">
          <ArrowLeft className="w-4 h-4" />
          Retour
        </Button>
      </div>

      {/* Barre de progression */}
      <div className="mb-6">
        <div className="flex items-center justify-between mb-2">
          <span className="text-sm font-medium">Finalisation</span>
          <span className={`text-sm font-medium ${getStatusColor()}`}>
            {getStatusMessage()}
          </span>
        </div>
        <Progress 
          value={submitStatus === 'success' ? 100 : submitStatus !== 'idle' ? 50 : 0} 
          className="h-2" 
        />
      </div>

      {/* Section CV - Upload ou Affichage */}
      <Card className="mb-6">
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            <FileText className="w-5 h-5" />
            Votre CV
          </CardTitle>
        </CardHeader>
        <CardContent>
          {savedCV && !showCVUpload ? (
            // Afficher le CV uploadé précédemment avec option de changer
            <div className="space-y-4">
              <div className="p-4 bg-green-50 border border-green-200 rounded-lg">
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-3">
                    <FileText className="w-8 h-8 text-green-600" />
                    <div>
                      <p className="font-medium text-green-800">{savedCV.name}</p>
                      <p className="text-sm text-green-600">
                        {(savedCV.size / 1024 / 1024).toFixed(2)} MB • {savedCV.type}
                      </p>
                    </div>
                  </div>
                  <Button 
                    variant="outline" 
                    size="sm"
                    onClick={() => setShowCVUpload(true)}
                  >
                    Changer le CV
                  </Button>
                </div>
              </div>
              <p className="text-sm text-gray-600">
                Votre CV est prêt pour la soumission. Cliquez sur "Changer le CV" si vous souhaitez modifier votre sélection.
              </p>
            </div>
          ) : (
            // Afficher l'upload
            <div className="space-y-4">
              <div className="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-gray-400 transition-colors">
                <Upload className="w-12 h-12 text-gray-400 mx-auto mb-4" />
                <p className="text-lg font-medium text-gray-700 mb-2">
                  {savedCV ? 'Choisir un nouveau CV' : 'Déposez votre CV ici'}
                </p>
                <p className="text-sm text-gray-500 mb-4">
                  Formats acceptés : PDF, DOC, DOCX (max 5MB)
                </p>
                <input
                  type="file"
                  accept=".pdf,.doc,.docx"
                  onChange={handleFileChange}
                  className="hidden"
                  id="cv-upload"
                />
                <label htmlFor="cv-upload">
                  <Button className="cursor-pointer">
                    <Upload className="w-4 h-4 mr-2" />
                    Sélectionner un fichier
                  </Button>
                </label>
              </div>
              {savedCV && (
                <Button 
                  variant="outline" 
                  onClick={() => setShowCVUpload(false)}
                  className="w-full"
                >
                  Annuler et conserver le CV précédent
                </Button>
              )}
            </div>
          )}
        </CardContent>
      </Card>

      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* Résultats de l'analyse IA */}
        {analysis && (
          <Card className="mb-6 border-green-200 bg-green-50">
            <CardHeader>
              <CardTitle className="text-lg flex items-center gap-2">
                <Brain className="w-5 h-5 text-green-600" />
                Analyse IA de votre CV
                {isPending && <Loader2 className="w-4 h-4 animate-spin ml-2" />}
              </CardTitle>
            </CardHeader>
            <CardContent>
              {error ? (
                <div className="text-red-600 text-sm p-3 bg-red-50 rounded border border-red-200">
                  Erreur d'analyse: {String(error?.message || error)}
                </div>
              ) : (
                <div className="space-y-4">
                  {/* Informations de base */}
                  {analysis.basic_information && (
                    <div>
                      <h5 className="text-sm font-semibold text-gray-900 mb-2 flex items-center gap-2">
                        <CheckCircle className="w-4 h-4 text-green-600" />
                        Informations de base
                      </h5>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                        {analysis?.basic_information?.full_name && (
                          <div>
                            <span className="font-medium">Nom:</span> {analysis.basic_information.full_name}
                          </div>
                        )}
                        {analysis?.basic_information?.email && (
                          <div>
                            <span className="font-medium">Email:</span> {analysis.basic_information.email}
                          </div>
                        )}
                        {analysis?.basic_information?.phone && (
                          <div>
                            <span className="font-medium">Téléphone:</span> {analysis.basic_information.phone}
                          </div>
                        )}
                      </div>
                    </div>
                  )}

                  {/* Domaine et technologies */}
                  {analysis?.technical_information && (
                    <div>
                      <h5 className="text-sm font-semibold text-gray-900 mb-2 flex items-center gap-2">
                        <Star className="w-4 h-4 text-blue-600" />
                        Domaine et Technologies
                      </h5>
                      <div className="space-y-2">
                        {analysis?.technical_information?.domain && (
                          <div className="text-sm">
                            <span className="font-medium">Domaine:</span> 
                            <Badge variant="secondary" className="ml-2">
                              {analysis.technical_information.domain}
                            </Badge>
                          </div>
                        )}
                        {analysis?.technical_information?.technologies && analysis.technical_information.technologies.length > 0 && (
                          <div className="text-sm">
                            <span className="font-medium">Technologies:</span>
                            <div className="flex flex-wrap gap-1 mt-1">
                              {analysis.technical_information.technologies.map((tech: any, index: number) => (
                                <Badge key={index} variant="outline" className="text-xs">
                                  {tech.name} ({tech.skill_level})
                                </Badge>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    </div>
                  )}

                  {/* Compétences */}
                  {analysis.soft_skills && (
                    <div>
                      <h5 className="text-sm font-semibold text-gray-900 mb-2">Compétences comportementales</h5>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                        {analysis.soft_skills.communication_skills && analysis.soft_skills.communication_skills.length > 0 && (
                          <div>
                            <span className="font-medium">Communication:</span>
                            <div className="flex flex-wrap gap-1 mt-1">
                              {analysis.soft_skills.communication_skills.map((skill: string, index: number) => (
                                <Badge key={index} variant="outline" className="text-xs">
                                  {skill}
                                </Badge>
                              ))}
                            </div>
                          </div>
                        )}
                        {analysis.soft_skills.leadership_skills && analysis.soft_skills.leadership_skills.length > 0 && (
                          <div>
                            <span className="font-medium">Leadership:</span>
                            <div className="flex flex-wrap gap-1 mt-1">
                              {analysis.soft_skills.leadership_skills.map((skill: string, index: number) => (
                                <Badge key={index} variant="outline" className="text-xs">
                                  {skill}
                                </Badge>
                              ))}
                            </div>
                          </div>
                        )}
                        {analysis.soft_skills.problem_solving && analysis.soft_skills.problem_solving.length > 0 && (
                          <div>
                            <span className="font-medium">Résolution de problèmes:</span>
                            <div className="flex flex-wrap gap-1 mt-1">
                              {analysis.soft_skills.problem_solving.map((skill: string, index: number) => (
                                <Badge key={index} variant="outline" className="text-xs">
                                  {skill}
                                </Badge>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    </div>
                  )}

                  {/* Certifications */}
                  {analysis.certifications && analysis.certifications.length > 0 && (
                    <div>
                      <h5 className="text-sm font-semibold text-gray-900 mb-2">Certifications</h5>
                      <div className="space-y-2">
                        {analysis.certifications.map((cert: any, index: number) => (
                          <div key={index} className="p-2 bg-gray-50 rounded border">
                            <div className="text-sm font-medium">{cert.certification_name}</div>
                            {cert.issuing_organization && (
                              <div className="text-xs text-gray-600">Délivré par: {cert.issuing_organization}</div>
                            )}
                            {cert.issue_date && (
                              <div className="text-xs text-gray-600">Date: {cert.issue_date}</div>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* Projets */}
                  {analysis.projects_list && analysis.projects_list.length > 0 && (
                    <div>
                      <h5 className="text-sm font-semibold text-gray-900 mb-2">Projets détectés</h5>
                      <div className="space-y-2">
                        {analysis.projects_list.map((project: any, index: number) => (
                          <div key={index} className="p-2 bg-gray-50 rounded border">
                            <div className="text-sm font-medium">{project.name}</div>
                            <div className="text-xs text-gray-600">Rôle: {project.role}</div>
                            {project.tech_stack && project.tech_stack.length > 0 && (
                              <div className="flex flex-wrap gap-1 mt-1">
                                {project.tech_stack.map((tech: string, techIndex: number) => (
                                  <Badge key={techIndex} variant="outline" className="text-xs">
                                    {tech}
                                  </Badge>
                                ))}
                              </div>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              )}
            </CardContent>
          </Card>
        )}

        {/* Récapitulatif des candidatures */}
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-2">
              <CheckCircle className="w-5 h-5 text-blue-600" />
              Récapitulatif ({selectedPositions.length} candidature{selectedPositions.length > 1 ? 's' : ''})
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div className="space-y-3">
              {selectedPositions.map((position, index) => (
                <div key={position.id} className="flex items-start gap-3 p-3 bg-gray-50 rounded-lg border">
                  <span className="text-sm font-bold text-blue-600 mt-1">#{index + 1}</span>
                  <div className="flex-1">
                    <h4 className="text-sm font-semibold text-gray-900">{position.title}</h4>
                    <p className="text-xs text-gray-600 mt-1 line-clamp-2">{position.description}</p>
                  </div>
                  <Badge variant="outline" className="text-xs">
                    En attente
                  </Badge>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>

        {/* Téléchargement du CV - MASQUÉ si CV déjà uploadé */}
        {showCVUpload && (
          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <FileText className="w-5 h-5" />
                Votre CV
              </CardTitle>
            </CardHeader>
            <CardContent>
              <div className="space-y-4">
                <div>
                  <label htmlFor="cv-upload" className="block text-sm font-medium text-gray-700 mb-2">
                    Sélectionnez votre CV
                  </label>
                  <div className="relative">
                    <input
                      id="cv-upload"
                      type="file"
                      accept=".pdf,.doc,.docx"
                      onChange={handleFileChange}
                      disabled={isSubmitting}
                      className="hidden"
                    />
                    <label
                      htmlFor="cv-upload"
                      className={`flex items-center justify-center gap-2 p-4 border-2 border-dashed rounded-lg cursor-pointer transition-colors ${
                        cvFile 
                          ? 'border-green-500 bg-green-50' 
                          : 'border-gray-300 hover:border-gray-400'
                      } ${isSubmitting ? 'cursor-not-allowed opacity-50' : ''}`}
                    >
                      {cvFile ? (
                        <>
                          <CheckCircle className="w-5 h-5 text-green-600" />
                          <span className="text-sm font-medium text-green-700">{cvFile.name}</span>
                        </>
                      ) : (
                        <>
                          <Upload className="w-5 h-5 text-gray-400" />
                          <span className="text-sm text-gray-600">Cliquez pour sélectionner</span>
                        </>
                      )}
                    </label>
                  </div>
                </div>

                <div className="text-xs text-gray-600 space-y-1">
                  <p>• Formats acceptés: PDF, DOC, DOCX</p>
                  <p>• Taille maximale: 5MB</p>
                  <p>• Votre CV sera analysé automatiquement</p>
                </div>

                {errorMessage && (
                  <div className="flex items-center gap-2 p-3 bg-red-50 border border-red-200 rounded-lg">
                    <AlertCircle className="w-4 h-4 text-red-600" />
                    <span className="text-sm text-red-700">{errorMessage}</span>
                  </div>
                )}
              </div>
            </CardContent>
          </Card>
        )}

      {/* Bouton de soumission */}
      <div className="mt-6">
        <Button 
          onClick={handleSubmit}
          disabled={isSubmitting || selectedPositions.length === 0 || (!cvFile && !savedCV)}
          className="w-full"
        >
          {isSubmitting ? (
            <>
              <Loader2 className="w-4 h-4 mr-2 animate-spin" />
              {submitStatus === 'uploading' ? 'Téléchargement...' : 
               submitStatus === 'processing' ? 'Traitement...' : 'Soumission...'}
            </>
          ) : (
            'Soumettre mes candidatures'
          )}
        </Button>
      </div>

      {/* Message de succès */}
      {submitStatus === 'success' && (
        <Card className="mt-6 border-green-200 bg-green-50">
          <CardContent className="pt-6">
            <div className="text-center">
              <CheckCircle className="w-12 h-12 text-green-600 mx-auto mb-4" />
              <h3 className="text-lg font-semibold text-green-800 mb-2">
                Candidatures soumises avec succès !
              </h3>
              <p className="text-green-700 mb-4">
                Vos {selectedPositions.length} candidature{selectedPositions.length > 1 ? 's' : ''} ont été soumises et sont en cours de traitement.
                Vous serez redirigé vers votre espace candidatures dans quelques instants...
              </p>
              <div className="flex items-center justify-center gap-2">
                <Loader2 className="w-4 h-4 animate-spin text-green-600" />
                <span className="text-sm text-green-600">Redirection en cours...</span>
              </div>
            </div>
          </CardContent>
        </Card>
      )}
    </div>
  );
};
